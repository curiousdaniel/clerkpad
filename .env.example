# Neon on Vercel injects these (use `vercel env pull`). The app uses a pooled URL:
# POSTGRES_URL, or if unset, DATABASE_URL.
POSTGRES_URL=
# DATABASE_URL=

# Required in production (use the same value for both if you set both):
# openssl rand -base64 32
NEXTAUTH_SECRET=
# AUTH_SECRET=

# Production: https://your-domain.vercel.app (must match the public URL so password-reset links work)
NEXTAUTH_URL=http://localhost:3000

# Password reset emails (Resend — https://resend.com). Without these, forgot-password returns an error after creating a token.
RESEND_API_KEY=
# Verified sender, e.g. ClerkBid <onboarding@resend.dev> or your domain
RESEND_FROM=

# Optional (not used by app code; useful for migrations / Prisma / scripts):
# POSTGRES_URL_NON_POOLING=  (or DATABASE_URL_UNPOOLED for direct connections)
