# Neon on Vercel injects these (use `vercel env pull`). The app uses a pooled URL:
# POSTGRES_URL, or if unset, DATABASE_URL.
POSTGRES_URL=
# DATABASE_URL=

# Required in production (use the same value for both if you set both):
# openssl rand -base64 32
NEXTAUTH_SECRET=
# AUTH_SECRET=

# Production: https://your-domain.vercel.app (must match the public URL so password-reset links work)
NEXTAUTH_URL=http://localhost:3000

# --- Email (Resend) — required for password reset and the /feedback form ---
# 1. Create an account at https://resend.com and create an API key.
# 2. CRITICAL: RESEND_FROM must use a domain you have added AND verified under
#    https://resend.com/domains (DNS records). Using e.g. noreply@auctionmethod.com
#    will fail with 403 until auctionmethod.com is verified in *your* Resend team.
#    Until then, verify clerkbid.com (or another domain) and use that in FROM, or
#    use Resend’s documented test/onboarding sender for non-production only.
# 3. In Vercel: Project → Settings → Environment Variables (Production):
#      RESEND_API_KEY=re_...
#      RESEND_FROM=ClerkBid <noreply@your-verified-domain.com>
#      NEXTAUTH_URL=https://clerkbid.com
# 4. Redeploy after changing variables.
RESEND_API_KEY=
RESEND_FROM=

# Where feedback submissions are delivered (defaults to info@auctionmethod.com).
# FEEDBACK_TO_EMAIL=info@auctionmethod.com

# Vercel Cron (monthly backup email). Generate a random secret; set the same value
# in Vercel → Project → Settings → Environment Variables as CRON_SECRET.
# Vercel sends: Authorization: Bearer <CRON_SECRET> to /api/cron/backup-email/
# CRON_SECRET=

# Optional (not used by app code; useful for migrations / Prisma / scripts):
# POSTGRES_URL_NON_POOLING=  (or DATABASE_URL_UNPOOLED for direct connections)
